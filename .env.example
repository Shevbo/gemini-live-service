# Gemini API
GEMINI_API_KEY=

# Proxy для Google API (обязательно! — взять из ~/.openclaw/openclaw.json → models.providers.google.request.proxy.url)
GOOGLE_PROXY_URL=http://user:pass@host:port

# Database (существующий PostgreSQL на :5432)
DATABASE_URL=postgresql://user:password@localhost:5432/gemini_live

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth tokens (генерировать: python -c "import secrets; print(secrets.token_hex(32))")
BORIS_TOKEN=
MARIA_TOKEN=
DANIELA_TOKEN=

# Audio storage (внутри контейнера)
AUDIO_STORAGE_PATH=/app/audio_storage

# OpenClaw notification
OPENCLAW_NOTIFY_URL=http://localhost:18789/api/notify

# Окружение
ENVIRONMENT=production
LOG_LEVEL=INFO
